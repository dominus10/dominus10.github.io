{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "lib": [
      "es6",
      "dom",
      "dom.iterable"
    ],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      },
    ],
    "resolveJsonModule": true,
    "strictNullChecks": true,
  }
}